# agent-lsp combo image — multiple language servers
# Build with: docker build -f Dockerfile.combo \
#   --build-arg NPM_PACKAGES="typescript-language-server typescript pyright" \
#   --build-arg GO_PACKAGES="golang.org/x/tools/gopls@latest" \
#   -t ghcr.io/blackwell-systems/agent-lsp:fullstack .

FROM debian:bookworm-slim

# ── Base layer (inlined from Dockerfile.release to avoid registry pull race) ──
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git \
    && rm -rf /var/lib/apt/lists/*

COPY agent-lsp /usr/local/bin/agent-lsp
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY docker/lsp-servers.yaml /etc/agent-lsp/lsp-servers.yaml
RUN chmod +x /usr/local/bin/entrypoint.sh
RUN mkdir -p /var/cache/lsp-servers
RUN groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /usr/sbin/nologin nonroot \
    && chown -R nonroot:nonroot /var/cache/lsp-servers

EXPOSE 8080
ENV HOME=/tmp
RUN mkdir -p /workspace && chown nonroot:nonroot /workspace
WORKDIR /workspace

# ── Language server layer ─────────────────────────────────────────────────────
ARG NPM_PACKAGES=""
ARG GO_PACKAGES=""

RUN if [ -n "${NPM_PACKAGES}" ]; then \
      apt-get update && apt-get install -y --no-install-recommends nodejs npm && \
      npm install -g ${NPM_PACKAGES} && \
      rm -rf /var/lib/apt/lists/*; \
    fi

RUN if [ -n "${GO_PACKAGES}" ]; then \
      LATEST_GO=$(curl -fsSL "https://go.dev/VERSION?m=text" | head -1) && \
      GOARCH=$(dpkg --print-architecture) && \
      curl -fsSL "https://dl.google.com/go/${LATEST_GO}.linux-${GOARCH}.tar.gz" -o /tmp/go.tar.gz && \
      tar -C /usr/local -xzf /tmp/go.tar.gz && \
      rm /tmp/go.tar.gz && \
      GOPATH=/usr/local /usr/local/go/bin/go install ${GO_PACKAGES}; \
    fi

ENV PATH=$PATH:/usr/local/go/bin

USER nonroot

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
