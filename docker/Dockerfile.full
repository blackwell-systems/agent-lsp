# agent-lsp full image — ALL supported language servers
# WARNING: This image is 2-3 GB. For zero-setup use only.
# For targeted use, prefer per-language tags: ghcr.io/blackwell-systems/agent-lsp:<lang>
#
# Pull: docker pull ghcr.io/blackwell-systems/agent-lsp:full

FROM debian:bookworm-slim

# ── Base layer (inlined from Dockerfile.release to avoid registry pull race) ──
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git \
    && rm -rf /var/lib/apt/lists/*

COPY agent-lsp /usr/local/bin/agent-lsp
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY docker/lsp-servers.yaml /etc/agent-lsp/lsp-servers.yaml
RUN chmod +x /usr/local/bin/entrypoint.sh
RUN mkdir -p /var/cache/lsp-servers
RUN groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /usr/sbin/nologin nonroot \
    && chown -R nonroot:nonroot /var/cache/lsp-servers

EXPOSE 8080
ENV HOME=/tmp
RUN mkdir -p /workspace && chown nonroot:nonroot /workspace
WORKDIR /workspace

# ── Language servers ──────────────────────────────────────────────────────────

# Install Node.js (needed for npm-based servers)
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# npm-based language servers
RUN npm install -g \
    typescript-language-server typescript \
    pyright \
    intelephense \
    yaml-language-server \
    vscode-langservers-extracted \
    dockerfile-language-server-nodejs \
    @prisma/language-server \
    && npm cache clean --force

# Go + gopls (bookworm's golang-go is too old for gopls; install from go.dev)
RUN LATEST_GO=$(curl -fsSL "https://go.dev/VERSION?m=text" | head -1) \
    && GOARCH=$(dpkg --print-architecture) \
    && curl -fsSL "https://dl.google.com/go/${LATEST_GO}.linux-${GOARCH}.tar.gz" -o /tmp/go.tar.gz \
    && tar -C /usr/local -xzf /tmp/go.tar.gz \
    && rm /tmp/go.tar.gz \
    && GOPATH=/usr/local /usr/local/go/bin/go install golang.org/x/tools/gopls@latest

ENV PATH=$PATH:/usr/local/go/bin

# Ruby + solargraph (build-essential needed for prism native C extension)
RUN apt-get update && apt-get install -y --no-install-recommends ruby-full build-essential \
    && gem install solargraph \
    && rm -rf /var/lib/apt/lists/*

# C/C++ via clangd
RUN apt-get update && apt-get install -y --no-install-recommends clangd \
    && rm -rf /var/lib/apt/lists/*

# C# (csharp-ls): NuGet package lacks DotnetToolSettings.xml — unreliable for global tool install.
# Use LSP_SERVERS=csharp-ls at runtime, or install manually. Not included in this image.

# The following language servers require platform-specific installation and are
# NOT included in the full image. Use LSP_SERVERS or install manually:
# - rust-analyzer (Rust): rustup component add rust-analyzer
# - jdtls (Java): see https://download.eclipse.org/jdtls/snapshots/
# - kotlin-language-server (Kotlin): see https://github.com/fwcd/kotlin-language-server/releases
# - sourcekit-lsp (Swift): ships with Xcode on macOS only
# - elixir-ls (Elixir): build from source
# - clojure-lsp (Clojure): binary release from GitHub
# - dart language-server (Dart): install Dart SDK
# - lua-language-server (Lua): binary release from GitHub
# - zls (Zig): match Zig version exactly
# - metals (Scala): requires sbt compilation
# - haskell-language-server (Haskell): install via GHCup
# - terraform-ls (Terraform): binary release from hashicorp.com

LABEL org.opencontainers.image.description="agent-lsp with all supported language servers (~2-3 GB)"

USER nonroot

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
