# agent-lsp per-language image
# Build with: docker build -f Dockerfile.lang --build-arg LANG=go \
#   --build-arg LSP_PACKAGE="golang.org/x/tools/gopls@latest" \
#   --build-arg PACKAGE_MGR=go \
#   --build-arg LSP_BINARY=gopls \
#   -t ghcr.io/blackwell-systems/agent-lsp:go .

ARG BASE_TAG=base
FROM ghcr.io/blackwell-systems/agent-lsp:${BASE_TAG}

ARG LANG
ARG LSP_PACKAGE
ARG PACKAGE_MGR
ARG LSP_BINARY

# Base image runs as nonroot — switch to root for package installation
USER root

# Install language server based on package manager
RUN set -eux; \
    case "${PACKAGE_MGR}" in \
      npm) \
        apt-get update && apt-get install -y --no-install-recommends nodejs npm && \
        npm install -g ${LSP_PACKAGE} ;; \
      go) \
        LATEST_GO=$(curl -fsSL "https://go.dev/VERSION?m=text" | head -1) && \
        curl -fsSL "https://dl.google.com/go/${LATEST_GO}.linux-amd64.tar.gz" -o /tmp/go.tar.gz && \
        tar -C /usr/local -xzf /tmp/go.tar.gz && \
        rm /tmp/go.tar.gz && \
        GOPATH=/usr/local /usr/local/go/bin/go install ${LSP_PACKAGE} ;; \
      apt) \
        apt-get update && apt-get install -y --no-install-recommends ${LSP_PACKAGE} ;; \
      gem) \
        apt-get update && apt-get install -y --no-install-recommends ruby-full build-essential && \
        gem install ${LSP_PACKAGE} ;; \
      pip) \
        apt-get update && apt-get install -y --no-install-recommends python3-pip && \
        pip3 install --break-system-packages ${LSP_PACKAGE} ;; \
      dotnet) \
        echo "dotnet: csharp-ls NuGet package is not a valid global tool (missing DotnetToolSettings.xml). Use LSP_SERVERS at runtime instead." && exit 1 ;; \
      *) \
        echo "PACKAGE_MGR=${PACKAGE_MGR}: manual install not supported in Dockerfile.lang; use entrypoint LSP_SERVERS instead" && exit 1 ;; \
    esac && \
    rm -rf /var/lib/apt/lists/*

ENV PATH=$PATH:/usr/local/bin:/usr/local/go/bin

# Set language label
LABEL org.opencontainers.image.description="agent-lsp with ${LANG} language server"

USER nonroot
