# Copy to .env and fill in your values.
# Required:
WORKSPACE_DIR=/path/to/your/project

# Optional: comma-separated language servers to install at container startup
# (only needed if using the base image without per-language tags)
# LSP_SERVERS=gopls,typescript-language-server

# Optional: override the image tag (default: base, built locally)
# AGENT_LSP_TAG=go
