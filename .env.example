# Copy to .env and fill in your values.
# Required:
WORKSPACE_DIR=/path/to/your/project

# Optional: comma-separated language servers to install at container startup
# (only needed if using the base image without per-language tags)
# LSP_SERVERS=gopls,typescript-language-server

# Required for HTTP mode (agent-lsp-http service): Bearer token for authentication.
# Set to a strong random value. Never leave empty in production.
# Generate one with: openssl rand -hex 32
# AGENT_LSP_TOKEN=your-secret-token-here

# Optional: override the image tag (default: base, built locally)
# AGENT_LSP_TAG=go
