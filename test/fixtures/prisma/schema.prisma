datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@localhost:5432/prismatest?schema=public"
}

generator client {
  provider = "prisma-client-js"
}

model Person {
  id    Int    @id @default(autoincrement())
  name  String
  age   Int
  posts Post[]
}

model Post {
  id       Int    @id @default(autoincrement())
  title    String
  authorId Int
  author   Person @relation(fields: [authorId], references: [id])
}
